# Copy this file to .env and fill in the values.

# Twilio WhatsApp settings.
# In Twilio, WhatsApp numbers look like: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

MAX_ARTICLES_PER_SECTION=5
LOOKBACK_HOURS=36

# Sending mode:
# - false: print the digest in your terminal for testing
# - true: send it to WhatsApp
SEND_WHATSAPP=false
